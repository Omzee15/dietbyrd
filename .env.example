# ── Database (required) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ── App environment ──────────────────────────────────────────────────
# "dev" prints OTP codes to the console instead of sending real SMS/WhatsApp
APP_ENV=production
PORT=3001

# ── Auth / security secrets (required in production) ────────────────
# Signs registration/referral tokens. MUST be set to a long random value
# in production - the code falls back to a hardcoded default otherwise.
REGISTRATION_TOKEN_SECRET=
# Signs time-limited patient document download links. Falls back to
# REGISTRATION_TOKEN_SECRET if unset, but a distinct secret is safer.
DOCUMENT_URL_SECRET=

# ── Razorpay (payments) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
VITE_RAZORPAY_KEY_ID=
# Required for /api/payments/webhook to accept any requests at all
# (Razorpay dashboard -> Settings -> Webhooks -> Secret)
RAZORPAY_WEBHOOK_SECRET=

# ── Twilio (OTP / SMS / WhatsApp) ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_TEMPLATE_WELCOME_SID=
TWILIO_TEMPLATE_REFERRAL_SID=
# "sms" or "whatsapp" - controls which channel referral registration links use
REFERRAL_SMS_MODE=

# ── SendGrid (email) ──────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=DietByRD

# ── Supabase (optional file storage for patient documents) ──────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Meta / WhatsApp webhook verification ─────────────────────────────
META_VERIFY_TOKEN=

# ── URLs used when building links in emails/SMS ──────────────────────
PUBLIC_SITE_URL=
FRONTEND_URL=

# ── Misc / operational toggles ────────────────────────────────────────
PGPOOL_MAX=1
PG_CONNECTION_TIMEOUT_MS=10000
ENABLE_AUTO_ASSIGN_SCHEDULER=false
RUN_STARTUP_MAINTENANCE=false
RUN_FOOD_LIBRARY_SEED_ON_STARTUP=false

# These are set automatically by Netlify/Vercel - do not set manually
# VITE_API_URL is not needed - the frontend API client uses relative paths
